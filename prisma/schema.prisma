generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id String @id @default(cuid())
  nickname String
  createdAt DateTime @default(now())
  schedules Schedule[]
}

model Schedule {
  id String @id @default(cuid())
  userId String
  date DateTime
  startMinutes Int
  endMinutes Int
  locationName String
  latitude Float
  longitude Float
  radiusMeters Int @default(1500)
  createdAt DateTime @default(now())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([date])
  @@index([userId])
}
